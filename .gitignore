# ============================================
# Kalimati Market Analytics System - .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
.pytest_cache/
venv/
.venv/

# ---------- Node.js ----------
node_modules/
dist/
dist-ssr/
*.local

# ---------- Environment / Secrets ----------
.env
.env.*

# ---------- Large Data Files ----------
# These are regenerated by the data pipeline
*.csv
*.parquet
*.db

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# ---------- OS ----------
Thumbs.db
Desktop.ini
